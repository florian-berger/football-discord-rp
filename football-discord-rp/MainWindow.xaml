<Window x:Class="football_discord_rp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:app="clr-namespace:football_discord_rp"
        xmlns:viewModel="clr-namespace:football_discord_rp.ViewModel"
        xmlns:converters="clr-namespace:football_discord_rp.Converters"
        xmlns:model="clr-namespace:football_discord_rp.Model"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:interactivity="http://prismlibrary.com/"
        ui:WindowHelper.UseModernWindowStyle="True"
        mc:Ignorable="d" Title="{x:Static app:FootballDiscordRp.WindowTitle}" Height="600" Width="500"
        ResizeMode="NoResize">
    <Window.Resources>
        <converters:SelectedDetailTypeToBooleanConverter x:Key="SelectedDetailTypeToBooleanConverter" />
        <converters:NotNullToVisibilityConverter x:Key="NotNullToVisibilityConverter" />
    </Window.Resources>

    <Window.DataContext>
        <viewModel:MainViewModel />
    </Window.DataContext>

    <b:Interaction.Triggers>
        <b:EventTrigger EventName="ContentRendered">
            <interactivity:InvokeCommandAction Command="{Binding Path=LoadedCommand, Mode=OneTime}" />
        </b:EventTrigger>
    </b:Interaction.Triggers>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Main">
                <MenuItem Header="Exit" Command="{Binding Path=ExitCommand, Mode=OneTime}"
                          InputGestureText="Alt + F4"/>
            </MenuItem>

            <MenuItem Header="Settings">
                <MenuItem Header="Dark mode"
                          IsCheckable="True"
                          IsChecked="{Binding Path=IsDarkMode, Mode=TwoWay}"
                          CommandParameter="{x:Static ui:ApplicationTheme.Dark}"  />
            </MenuItem>

            <MenuItem Header="Help">
                <MenuItem Header="Open repository"
                          Command="{x:Static app:StaticCommands.OpenUriCommand}"
                          CommandParameter="{x:Static app:FootballDiscordRp.RepositoryUrl}" />
                <Separator />
                <MenuItem Header="Check for update" Command="{Binding Path=CheckVersionUpdateCommand, Mode=OneTime}" />
                <MenuItem Header="About …" Command="{x:Static app:StaticCommands.ShowAboutCommand}" />
            </MenuItem>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom" Padding="5">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Status:" FontWeight="Bold" Margin="0,0,5,0" />
                    <Image Source="{Binding Path=ConnectedUserAvatarSource, Mode=OneWay}"
                           Visibility="{Binding Path=ConnectedUserAvatarSource, Mode=OneWay, Converter={StaticResource NotNullToVisibilityConverter}}"
                           Height="16" VerticalAlignment="Center" Margin="0,0,5,0" />
                    <TextBlock Text="{Binding Path=ConnectionStateText, Mode=OneWay}" VerticalAlignment="Center" />
                </StackPanel>
            </StatusBarItem>

            <StatusBarItem HorizontalAlignment="Right"
                           Visibility="{Binding Path=NewVersionDownloadLink, Converter={StaticResource NotNullToVisibilityConverter}, Mode=OneWay}">
                <Button DockPanel.Dock="Right"
                        VerticalAlignment="Center"
                        Command="{x:Static app:StaticCommands.OpenUriCommand}"
                        CommandParameter="{Binding Path=NewVersionDownloadLink, Mode=OneWay}">
                    <Button.Template>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <ContentPresenter />
                        </ControlTemplate>
                    </Button.Template>

                    <TextBlock Text="Update available!"/>
                </Button>
            </StatusBarItem>
        </StatusBar>

        <Grid Margin="12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ui:SimpleStackPanel Spacing="10">
                <ComboBox ui:ControlHelper.Header="League" HorizontalAlignment="Stretch"
                          ItemsSource="{x:Static app:DataStore.AppLeagues}"
                          SelectedItem="{Binding Path=SelectedLeague, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          DisplayMemberPath="DisplayName" />

                <RadioButton Content="Watching conference" IsChecked="{Binding Path=SelectedDetailType,
                        Converter={StaticResource SelectedDetailTypeToBooleanConverter},
                        ConverterParameter={x:Static model:SelectedDetailType.DetailTypeConference}}" />

                <RadioButton Content="Watching single match" IsChecked="{Binding Path=SelectedDetailType,
                        Converter={StaticResource SelectedDetailTypeToBooleanConverter},
                        ConverterParameter={x:Static model:SelectedDetailType.DetailTypeMatchup}}" />

                <Grid Margin="25,-10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- ReSharper disable Xaml.PossibleNullReferenceException -->
                    <ComboBox Grid.Column="0" ui:ControlHelper.PlaceholderText="Home team" HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding Path=SelectedLeague.Clubs, Mode=OneWay}"
                                  SelectedItem="{Binding Path=SelectedHomeTeam, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  DisplayMemberPath="FullName"
                                  IsEnabled="{Binding Path=SelectedDetailType, 
                                    Converter={StaticResource SelectedDetailTypeToBooleanConverter},
                                    ConverterParameter={x:Static model:SelectedDetailType.DetailTypeMatchup}}"  />

                    <TextBlock Grid.Column="1" Text="vs." VerticalAlignment="Center" Margin="10,0" />

                    <ComboBox Grid.Column="2" ui:ControlHelper.PlaceholderText="Away team" HorizontalAlignment="Stretch"
                              ItemsSource="{Binding Path=SelectedLeague.Clubs, Mode=OneWay}"
                              SelectedItem="{Binding Path=SelectedAwayTeam, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              DisplayMemberPath="FullName"
                              IsEnabled="{Binding Path=SelectedDetailType, 
                                    Converter={StaticResource SelectedDetailTypeToBooleanConverter},
                                    ConverterParameter={x:Static model:SelectedDetailType.DetailTypeMatchup}}"  />
                    <!-- ReSharper restore Xaml.PossibleNullReferenceException -->
                </Grid>

                <RadioButton Content="Define custom detail" IsChecked="{Binding Path=SelectedDetailType,
                        Converter={StaticResource SelectedDetailTypeToBooleanConverter},
                        ConverterParameter={x:Static model:SelectedDetailType.DetailTypeCustom}}" />

                <TextBox Margin="28,-10,0,0" ui:ControlHelper.PlaceholderText="Enter your custom detail text"
                             Text="{Binding Path=CustomDetail, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding Path=SelectedDetailType, 
                                Converter={StaticResource SelectedDetailTypeToBooleanConverter},
                                ConverterParameter={x:Static model:SelectedDetailType.DetailTypeCustom}}" />

                <RadioButton Content="No details" IsChecked="{Binding Path=SelectedDetailType,
                        Converter={StaticResource SelectedDetailTypeToBooleanConverter},
                        ConverterParameter={x:Static model:SelectedDetailType.DetailTypeNone}}" />
            </ui:SimpleStackPanel>

            <ui:SimpleStackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12" HorizontalAlignment="Right" Spacing="10">
                <Button Content="Clear presence" Command="{Binding Path=ClearPresenceCommand, Mode=OneTime}" />
                <Button Content="Set presence" Command="{Binding Path=SetPresenceCommand, Mode=OneTime}" />
            </ui:SimpleStackPanel>
        </Grid>
    </DockPanel>
</Window>
